generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("SLACK_DATABASE_URL")
}

// ─── Pre-existing tables (never drop) ────────────────────────────────────────

model days_off {
  id            Int     @id @default(autoincrement())
  email         String?
  vacation_days Int?    @db.SmallInt
  sick_days     Int?    @db.SmallInt
}

model inventory {
  id           Int     @id @default(autoincrement())
  product_name String?
  size         String?
  in_stock     Int?
}

model n8n_vectors {
  id        String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  text      String?
  metadata  Json?
  embedding Unsupported("vector")?
}

// ─── Slack Service ────────────────────────────────────────────────────────────

model SlackMessage {
  id          String             @id @default(uuid())
  messageId   String             @unique
  recipient   String
  body        String
  mediaUrl    String?
  status      SlackMessageStatus @default(PENDING)
  slackMsgTs  String?
  channel     String?
  errorReason String?
  sentAt      DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([recipient])
  @@index([status])
  @@index([createdAt])
}

enum SlackMessageStatus {
  PENDING
  SENT
  FAILED
  DELIVERED
}


